# Change POSTGRES_PASSWORD (and the matching DATABASE_URL) before actually
# leaving this running anywhere reachable off your own machine.
# NODE_ENV=production is set by the `pnpm start` script itself, not here —
# Vite/SvelteKit warn if NODE_ENV is set inside a loaded .env file.
POSTGRES_USER=shinrin
POSTGRES_PASSWORD=shinrin
POSTGRES_DB=shinrin_prod
POSTGRES_PORT=5433

DATABASE_URL=postgresql://shinrin:shinrin@localhost:5433/shinrin_prod
