{
	"name": "shinrin",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "tsx scripts/dev.ts",
		"dev-debug": "LOG_LEVEL=debug tsx scripts/dev.ts",
		"dev-trace": "LOG_LEVEL=trace tsx scripts/dev.ts",
		"build": "vite build",
		"start": "NODE_ENV=production node --env-file=.env.production build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:dev:start": "docker compose --env-file .env.development -f compose.dev.yaml up",
		"db:dev:push": "drizzle-kit push --force",
		"db:dev:studio": "drizzle-kit studio",
		"db:dev:seed": "tsx src/lib/server/db/seed.ts",
		"db:dev:clean": "tsx src/lib/server/db/clean.ts",
		"db:prod:start": "docker compose --env-file .env.production -f compose.prod.yaml up",
		"db:prod:generate": "drizzle-kit generate --config drizzle.config.prod.ts",
		"db:prod:migrate": "drizzle-kit migrate --config drizzle.config.prod.ts",
		"db:prod:studio": "drizzle-kit studio --config drizzle.config.prod.ts"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"drizzle-valibot": "^0.4.2",
		"ky": "^2.0.2",
		"mode-watcher": "^1.1.0",
		"ollama": "^0.6.3",
		"pino": "^10.3.1",
		"valibot": "^1.4.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.24.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.60.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.19.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	}
}
